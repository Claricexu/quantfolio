# Quantfolio environment variables — copy this file to `.env` and fill in your values.
# `.env` is gitignored; `.env.example` is the tracked template.

# ─── Email alerts (api_server.py) ────────────────────────────────────────────
# Set SMTP_ENABLED=true to turn on the "Quantfolio Signal Brief" email after
# each 4:05 PM EST scheduled run. For Gmail, generate an App Password at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification).
SMTP_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
# Comma-separated list of recipients.
ALERT_TO=your-email@gmail.com
ALERT_SUBJECT=Quantfolio Signal Brief

# ─── SEC EDGAR contact (edgar_fetcher.py + diagnostics) ──────────────────────
# SEC requires an identifying User-Agent with a real contact email per
# https://www.sec.gov/os/accessing-edgar-data. Failures to identify result in
# rate-limit blocks. Use your own email — the bundled default will 403.
SEC_USER_AGENT=Quantfolio Research Bot your-email@example.com
SEC_CONTACT_EMAIL=your-email@example.com
